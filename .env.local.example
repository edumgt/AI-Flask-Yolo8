APP_ENV=local
FLASK_SECRET_KEY=local-change-this-secret-key
FLASK_DEBUG=true
DATABASE_URL=sqlite:///users.db
SESSION_TYPE=filesystem

AWS_ACCESS_KEY_ID=your_local_access_key
AWS_SECRET_ACCESS_KEY=your_local_secret_key
