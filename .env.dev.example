APP_ENV=dev
FLASK_SECRET_KEY=dev-change-this-secret-key
FLASK_DEBUG=false
DATABASE_URL=sqlite:///users.db
SESSION_TYPE=filesystem

AWS_ACCESS_KEY_ID=your_dev_access_key
AWS_SECRET_ACCESS_KEY=your_dev_secret_key
